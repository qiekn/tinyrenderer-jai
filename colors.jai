#import "Math";

// COLORS (RGBA, components in 0..1)
RED     :: Vector4.{1,    0,    0,    1};
GREEN   :: Vector4.{0,    1,    0,    1};
BLUE    :: Vector4.{0.25, 0.5,  1,    1};
WHITE   :: Vector4.{1,    1,    1,    1};
BLACK   :: Vector4.{0,    0,    0,    0};
CYAN    :: Vector4.{0,    1,    1,    1};
YELLOW  :: Vector4.{1,    0.78, 0,    1};

NAYSYER :: Vector4.{0.02, 0.15, 0.15, 1};
